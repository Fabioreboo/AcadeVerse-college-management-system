// Script to initialize CS subjects and update student data
import { initializeApp } from 'firebase/app';
import { getFirestore, doc, setDoc, updateDoc, collection, getDocs } from 'firebase/firestore';

// Firebase configuration
const firebaseConfig = {
  apiKey: "AIzaSyCpPe_yBvHWx9Dx3XNP4QeaqpnGUkyoTcQ",
  authDomain: "student-hub-4c936.firebaseapp.com",
  projectId: "student-hub-4c936",
  storageBucket: "student-hub-4c936.firebasestorage.app",
  messagingSenderId: "138164720264",
  appId: "1:138164720264:web:e26167a340dcaaa658c53d"
};

// Initialize Firebase
const app = initializeApp(firebaseConfig);
const db = getFirestore(app);

const CS_SUBJECTS = [
  'Data Structures',
  'Algorithms', 
  'Operating Systems',
  'DBMS',
  'Computer Networks',
  'Software Engineering'
];

async function initializeCSSubjects() {
  console.log('Initializing Computer Science subjects...');
  
  for (const subject of CS_SUBJECTS) {
    try {
      await setDoc(doc(db, 'subjects', subject.toLowerCase().replace(/\s+/g, '_')), {
        name: subject,
        department: 'Computer Science',
        code: subject.toUpperCase().replace(/\s+/g, '_'),
        credits: 3,
        createdAt: new Date(),
        updatedAt: new Date()
      });
      console.log(`Created subject: ${subject}`);
    } catch (error) {
      console.error(`Error creating subject ${subject}:`, error);
    }
  }
}

async function updateStudentsDepartment() {
  console.log('Updating all students to Computer Science department...');
  
  try {
    const studentsRef = collection(db, 'students');
    const studentsSnapshot = await getDocs(studentsRef);
    
    const updatePromises = [];
    studentsSnapshot.forEach((doc) => {
      updatePromises.push(
        updateDoc(doc.ref, {
          department: 'Computer Science',
          updatedAt: new Date()
        })
      );
    });
    
    await Promise.all(updatePromises);
    console.log(`Updated ${updatePromises.length} students with Computer Science department`);
  } catch (error) {
    console.error('Error updating students:', error);
  }
}

async function updateUsersDepartment() {
  console.log('Updating all student users to Computer Science department...');
  
  try {
    const usersRef = collection(db, 'users');
    const usersSnapshot = await getDocs(usersRef);
    
    const updatePromises = [];
    usersSnapshot.forEach((doc) => {
      const userData = doc.data();
      if (userData.role === 'student') {
        updatePromises.push(
          updateDoc(doc.ref, {
            department: 'Computer Science',
            updatedAt: new Date()
          })
        );
      }
    });
    
    await Promise.all(updatePromises);
    console.log(`Updated ${updatePromises.length} student users with Computer Science department`);
  } catch (error) {
    console.error('Error updating users:', error);
  }
}

async function run() {
  try {
    console.log('Starting CS department initialization...');
    
    await initializeCSSubjects();
    await updateStudentsDepartment();
    await updateUsersDepartment();
    
    console.log('CS department initialization completed successfully!');
  } catch (error) {
    console.error('Error during initialization:', error);
  }
}

run();